# Copy to .env next to app.py. Do not commit .env.
# Optional overrides are documented in config/settings.py (single source of truth).
# Switch LLM by setting LLM_PROVIDER. If unset, gemini is used when GEMINI_API_KEY is set, else openai.

LLM_PROVIDER=gemini
# LLM_PROVIDER=openai

# Gemini (Google AI Studio) - get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# LLM HTTP timeout in seconds (OpenAI client + Gemini request_options)
# LLM_REQUEST_TIMEOUT_SECONDS=120

# Optional: cap user text in prompts (characters)
# MAX_DENIAL_REASON_CHARS=8000
# MAX_FIELD_CHARS=2000

# Logging: rotating file size and retention
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5

# Knowledge-base URL ingest (python -m knowledge_base.ingest --urls): comma-separated allowed hosts
# INGEST_URL_HOST_ALLOWLIST=cms.gov,medicare.gov

# HTTP timeout (seconds) for each URL fetched during KB ingest (--urls)
# INGEST_URL_REQUEST_TIMEOUT_SECONDS=20

# Tokenizer-based chunking + embedding batches for KB ingest
# CHUNK_TOKEN_SIZE=256
# CHUNK_TOKEN_OVERLAP=32
# EMBEDDING_BATCH_SIZE=64

# Hugging Face Hub (optional): higher rate limits and faster downloads for embedding models
# (sentence-transformers / all-MiniLM-L6-v2). Create a read token at:
# https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here
